# msksim environment variables
# Copy this file to .env and fill in the values.
# .env is gitignored — never commit it.

# Path to the SQLite database file (relative to project root).
# The directory is created automatically if it does not exist.
MSKSIM_DB_PATH=./data/msksim.db

# Secret used for signing session cookies. Must be at least 32 characters.
# Generate a secure value with:
#   openssl rand -base64 48
MSKSIM_SESSION_SECRET=replace-me-with-at-least-32-chars-of-random-bytes
