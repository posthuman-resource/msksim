{
  "name": "msksim",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "predev": "npx tsx scripts/check-node-version.ts",
    "prestart": "npx tsx scripts/check-node-version.ts",
    "pretest": "npx tsx scripts/check-node-version.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "sim:smoke": "tsx scripts/sim-smoke.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --conditions=react-server scripts/migrate.ts",
    "users": "tsx --conditions=react-server scripts/users.ts"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "better-sqlite3": "^12.8.0",
    "comlink": "^4.4.2",
    "drizzle-orm": "^0.45.2",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "next": "16.2.2",
    "pure-rand": "^8.4.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "server-only": "^0.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.8.9",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  }
}
